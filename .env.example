APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost

VOIP_ENABLED=false
VOIP_RING_TIMEOUT_SECONDS=45
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=900
LIVEKIT_WEBHOOK_SECRET=
LIVEKIT_EMPTY_TIMEOUT_SECONDS=60
LIVEKIT_MAX_PARTICIPANTS_1V1=2
LIVEKIT_MAX_PARTICIPANTS_GROUP=10
VOIP_CALLS_QUEUE=calls
VOIP_DEVICE_TOKEN_PRUNE_DAYS=90
VOIP_ORPHANED_RINGING_MINUTES=5
VOIP_CALL_EVENTS_PRUNE_DAYS=90
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=
APNS_PRODUCTION=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=lumidb
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
PRESENCE_HEARTBEAT_INTERVAL_SECONDS=25
PRESENCE_OFFLINE_TTL_SECONDS=90

SHOPIFY_ADMIN_ID=
# Must match the Shopify app's API secret key (webhook + app proxy HMAC).
SHOPIFY_ADMIN_SECRET=
# Optional: manual Shopify Admin webhook signing secret from Settings > Notifications > Webhooks.
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SHOP=
SHOPIFY_API_VERSION=2026-07
SHOPIFY_APP_URL=
SHOPIFY_PROXY_SUBPATH=lumi
SHOPIFY_PUBLISH_PRODUCTS=true
SHOPIFY_ONLINE_STORE_PUBLICATION_ID=

CHAT_AI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
CHAT_AI_USER_EMAIL=ai@lumi.internal
CHAT_AI_USER_NAME="Lumi AI"
CHAT_AI_HISTORY_LIMIT=20
